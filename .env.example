# CodeLens — Environment Variables

# Required: Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Recommended: Raises GitHub API rate limit from 60 to 5,000 req/hr
# Create one at https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=your_github_token_here
